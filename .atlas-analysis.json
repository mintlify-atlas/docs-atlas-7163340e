  "keyFeatures": [
    "AI-powered WhatsApp chatbot with RAG (Retrieval Augmented Generation)",
    "Full e-commerce platform with React + Vite frontend",
    "PostgreSQL database with pgvector for semantic search",
    "Admin dashboard for order management and logistics",
    "BullMQ + Redis queue system for async message processing",
    "Real-time WebSocket communication via Socket.IO",
    "Anthropic Claude 3.5 Sonnet integration with function calling",
    "WhatsApp Cloud API integration with handover protocol",
    "Wompi payment gateway integration",
    "Venndelo logistics API for shipping and tracking",
    "Automated inventory management and stock control",
    "Knowledge base management with RAG capabilities",
    "PII filtering and privacy protection",
    "Multi-role user system (Admin, Warehouse, Support, Customer)"
  ],
